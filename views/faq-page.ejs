<%- include('partials/head', { page: 'faq' }) %>
<body class="faq-page">

<%- include('partials/intro') %>
<%- include('partials/nav') %>

<!-- Page header -->
<section class="faq-hero">
  <div class="faq-hero-card">
    <span class="section-eyebrow">★ Aisle 4 · Special Offers</span>
    <h1 class="section-h2">Got <span class="hi">Questions?</span></h1>
    <p class="faq-sub">Clip the coupon, get the answer. No loyalty card required.</p>
  </div>
</section>

<!-- Coupons -->
<div class="coupon-flyer-header">
  <span class="coupon-flyer-label">✂ &nbsp; this week's coupons &nbsp; ✂</span>
</div>

<div class="coupon-grid">
  <% faq.forEach((item, i) => { %>
    <article class="coupon-item<%= item.open ? ' is-clipped' : '' %>" data-coupon>

      <!-- Coupon face (clickable) -->
      <button class="coupon-face" aria-expanded="<%= item.open ? 'true' : 'false' %>">

        <!-- Cut line -->
        <div class="coupon-cut-strip" aria-hidden="true">
          <span class="cut-scissors">✂</span>
          <div class="cut-dashes"></div>
          <span class="cut-label">CUT HERE</span>
          <span class="cut-clipped-label">✓ CLIPPED</span>
        </div>

        <!-- Body -->
        <div class="coupon-row">

          <div class="coupon-side" aria-hidden="true">
            <span class="coupon-num"><%= item.num %></span>
            <span class="coupon-clip-word">Clip</span>
          </div>

          <div class="coupon-main">
            <span class="coupon-eyebrow">★ QUICK ANSWER</span>
            <p class="coupon-q"><%= item.question %></p>
            <div class="coupon-footer-row">
              <span class="coupon-expiry">VALID: AUG 11–13 2026</span>
              <span class="coupon-hint">✂ tap to clip</span>
            </div>
          </div>

        </div>
      </button>

      <!-- Answer stub -->
      <div class="coupon-stub" aria-hidden="<%= item.open ? 'false' : 'true' %>" role="region" aria-label="<%= item.question %>">
        <div class="coupon-stub-inner">
          <div class="stub-top">
            <span class="stub-check" aria-hidden="true">✓</span>
            <span class="stub-clipped-label">Clipped — here's your answer</span>
          </div>
          <p class="stub-answer"><%= item.answer %></p>
        </div>
      </div>

    </article>
  <% }) %>
</div>

<%- include('partials/footer') %>

<script>
  document.querySelectorAll('[data-coupon]').forEach(function(coupon) {
    var btn  = coupon.querySelector('.coupon-face');
    var stub = coupon.querySelector('.coupon-stub');

    btn.addEventListener('click', function() {
      var isOpen = coupon.classList.toggle('is-clipped');
      btn.setAttribute('aria-expanded', isOpen);
      stub.setAttribute('aria-hidden', !isOpen);
    });
  });
</script>

</body>
</html>
